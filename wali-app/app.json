{
  "expo": {
    "name": "Wali Santri",
    "owner": "kliksantridemo",
    "slug": "kliksantri-wali",
    "version": "1.0.0",
    "scheme": "klikpesantren-wali",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFFFFF",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/splash-icon.png",
          "imageWidth": 360
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#15803D",
          "defaultChannel": "wali-santri"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "usesCleartextTraffic": false,
            "networkInspector": false
          }
        }
      ]
    ],
    "updates": {
      "enabled": false,
      "url": "https://u.expo.dev/3ee670bd-7850-40eb-9799-1609db9a3341"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.klikpesantren.wali"
    },
    "android": {
      "package": "com.klikpesantren.wali",
      "googleServicesFile": "./google-services.json",
      "versionCode": 3,
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#15803D",
      "barStyle": "light-content",
      "translucent": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3ee670bd-7850-40eb-9799-1609db9a3341"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
